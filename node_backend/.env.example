PORT=9090
NODE_NAME=sg-1
NODE_TOKEN=change-me-node-token
CONTROL_PLANE_SHARED_TOKEN=change-me-node-token
PANEL_BASE_URL=http://localhost:8080
SINGBOX_CONFIG_PATH=./sing-box.generated.json
SINGBOX_RELOAD_COMMAND=systemctl restart meimei-sing-box.service
NODE_BINARY_PATH=/opt/meimei-node/node_backend
NODE_RESTART_COMMAND=systemctl restart meimei-node
PUBLIC_HOST=node.example.com
VLESS_PORT=443
TUIC_PORT=8443
HYSTERIA2_PORT=9443
VLESS_REALITY_PRIVATE_KEY=
VLESS_REALITY_PUBLIC_KEY=
VLESS_REALITY_SHORT_ID=
VLESS_REALITY_SERVER_NAME=www.cloudflare.com
VLESS_REALITY_HANDSHAKE_SERVER=www.cloudflare.com
VLESS_REALITY_HANDSHAKE_PORT=443
TLS_CERTIFICATE_PATH=/opt/meimei-node/tls.crt
TLS_KEY_PATH=/opt/meimei-node/tls.key
TLS_SERVER_NAME=node.example.com

# Note: Bandwidth collection is now pull-based (Panel polls Nodes)
# The /api/bandwidth-usage endpoint is authenticated with NODE_TOKEN
